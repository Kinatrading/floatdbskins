{
  "manifest_version": 3,
  "name": "CSFloat Колекції та Float",
  "version": "1.2.0",
  "description": "Підбір колекції, special та rarity для формування посилання на CSFloat DB.",
  "permissions": ["tabs", "scripting", "webRequest"],
  "host_permissions": ["https://csfloat.com/*"],
  "action": {
    "default_title": "CSFloat Колекції"
  },
  "background": {
    "service_worker": "background.js"
  }
}
